{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/bootstrap.py ${CLAUDE_PLUGIN_ROOT}/clean.py --incremental --db ${CLAUDE_PLUGIN_ROOT}/history.db",
            "async": true
          }
        ]
      }
    ]
  }
}
